<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>GeneticSharp</id>
    <version>2.6.0</version>
    <authors>Diego Giacomelli</authors>
    <owners>Diego Giacomelli</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <licenseUrl>https://github.com/giacomelli/GeneticSharp/blob/master/LICENSE</licenseUrl>
    <projectUrl>https://github.com/giacomelli/GeneticSharp</projectUrl>
    <iconUrl>https://github.com/giacomelli/GeneticSharp/raw/master/docs/logo/icon-64x64-transparent.png</iconUrl>
    <description>A fast, extensible, multi-platform and multithreading C# Genetic Algorithm library that simplifies the development of applications using Genetic Algorithms (GAs).</description>
    <releaseNotes>See changes at https://github.com/giacomelli/GeneticSharp.</releaseNotes>
    <tags>genetic-algorithms geneticsharp genetic algorithms</tags>
    <dependencies>
      <group targetFramework=".NETFramework4.6.2" />
      <group targetFramework=".NETStandard2.0" />
    </dependencies>
  </metadata>
</package>